{#- THE footer — defined once. Contact literals come from src/_data/site.json. -#}
<footer class="bg-cream border-t border-ink/10 pt-16 pb-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <a href="#top" class="serif text-2xl tracking-tightish">{{ site.name }}</a>
        <p class="text-mute text-[15px] mt-4 max-w-sm leading-relaxed">
          Online treniņu programmas stipram, lokanam ķermenim un mierpilnam prātam — sev ērtā laikā un vietā.
        </p>
        <!-- Sociālie tīkli — linki ar ikonām -->
        <div class="flex flex-wrap gap-3 mt-6">
          <a href="https://www.instagram.com/sintijadance.fitness/" target="_blank" rel="noopener" aria-label="Instagram"
             class="w-10 h-10 rounded-full bg-warm border border-ink/10 hover:bg-sageDk hover:text-warm hover:border-sageDk transition-colors flex items-center justify-center text-ink/70">
