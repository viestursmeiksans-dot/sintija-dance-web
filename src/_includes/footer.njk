{#- THE footer — defined once. Contact literals come from src/_data/site.json. -#}
<footer class="bg-cream border-t border-ink/10 pt-16 pb-10">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <a href="#top" class="serif text-2xl tracking-tightish">{{ site.name }}</a>
        <p class="text-mute text-[15px] mt-4 max-w-sm leading-relaxed">
          Online treniņu programmas stipram, lokanam ķermenim un mierpilnam prātam — sev ērtā laikā un vietā.
        </p>
      </div>
      <div class="md:col-span-3">
        <p class="text-[11px] uppercase tracking-[0.2em] text-mute mb-4">Programmas</p>
        <ul class="space-y-2 text-[15px]">
          <li><a href="#programmas" class="hover:text-sageDk transition-colors">Vingrošana</a></li>
          <li><a href="#programmas" class="hover:text-sageDk transition-colors">Ballet Fitness</a></li>
          <li><a href="#programmas" class="hover:text-sageDk transition-colors">Stiepšanās un relaksācija</a></li>
          <li><a href="#programmas" class="hover:text-sageDk transition-colors">Bali · Drīzumā</a></li>
        </ul>
      </div>
      <div class="md:col-span-4">
        <p class="text-[11px] uppercase tracking-[0.2em] text-mute mb-4">Sazinies</p>
        <ul class="space-y-2 text-[15px]">
          <li><a href="mailto:{{ site.email }}" class="hover:text-sageDk transition-colors">{{ site.email }}</a></li>
          <li><a href="tel:{{ site.phoneHref }}" class="hover:text-sageDk transition-colors">{{ site.phone }}</a></li>
          <li><a href="#davanu" class="hover:text-sageDk transition-colors">Dāvanu kartes</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-ink/10 mt-12 pt-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs text-mute">
      <p>© {{ site.year }} {{ site.fullName }}. Visas tiesības aizsargātas.</p>
      <div class="flex items-center gap-4">
        {% if site.social.instagram %}<a href="{{ site.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="text-mute hover:text-ink transition-colors"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>{% endif %}
        {% if site.social.facebook %}<a href="{{ site.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook" class="text-mute hover:text-ink transition-colors"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>{% endif %}
        {% if site.social.youtube %}<a href="{{ site.social.youtube }}" target="_blank" rel="noopener" aria-label="YouTube" class="text-mute hover:text-ink transition-colors"><svg width="20" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="m22 8-6 4 6 4V8z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg></a>{% endif %}
      </div>
    </div>
  </div>
</footer>
