<script>
  // Juridisko sadaļu logs (footera pogas: Privātuma politika, Noteikumi, Intelektuālais īpašums)
  (function() {
    const modal = document.getElementById('policy-modal');
    const closeBtn = document.getElementById('policy-modal-close');
    const bodies = document.querySelectorAll('.policy-body');
    if (!modal) return;
    const open = (which) => {
      bodies.forEach(b => b.classList.toggle('hidden', b.id !== 'policy-' + which));
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      modal.scrollTop = 0;
    };
    const close = () => {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    };
    document.querySelectorAll('[data-policy]').forEach(btn => {
      btn.addEventListener('click', () => open(btn.dataset.policy));
    });
    closeBtn.addEventListener('click', close);
    modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.classList.contains('hidden')) close(); });
  })();
</script>
