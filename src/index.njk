    if (c.intro) h += c.intro.map(p => '<p class="mt-4 text-ink/80 leading-relaxed">' + p + '</p>').join('');
    if (c.bulletsLead) h += '<p class="mt-5 text-ink/80 leading-relaxed">' + c.bulletsLead + '</p>';
    if (c.bullets) h += '<ul class="mt-3 space-y-1.5 text-ink/80 list-disc pl-5 marker:text-sageDk">' + c.bullets.map(b => '<li>' + b + '</li>').join('') + '</ul>';
    if (c.notes) h += c.notes.map(n => '<p class="mt-4 text-ink/80 leading-relaxed">' + n + '</p>').join('');
    if (c.warn) h += '<p class="mt-5 text-ink/90 leading-relaxed bg-sand border border-ink/10 rounded-xl p-4"><span class="text-rose font-medium">!</span> ' + c.warn + '</p>';
    return h;
  }
  function openKlatiene(el, key) {
    const c = KLATIENE[key];
    if (!c) return;
    document.querySelectorAll('.kl-card').forEach(x => x.classList.remove('kl-selected'));
    if (el) el.classList.add('kl-selected');
    document.getElementById('klatiene-title').textContent = c.name;
    document.getElementById('klatiene-price').textContent = c.price || '';
    document.getElementById('klatiene-desc').innerHTML = renderKlatiene(c);
    const box = document.getElementById('klatiene-info');
    box.classList.remove('hidden');
    requestAnimationFrame(() => box.scrollIntoView({ behavior: 'smooth', block: 'start' }));
  }
  function closeKlatiene() {
    document.getElementById('klatiene-info').classList.add('hidden');
    document.querySelectorAll('.kl-card').forEach(x => x.classList.remove('kl-selected'));
  }
  window.openKlatiene = openKlatiene;
  window.closeKlatiene = closeKlatiene;

  // 1:1 individual training box
  function toggleSolo(el) {
    const box = document.getElementById('klatiene-solo');
    const opening = box.classList.contains('hidden');
    document.querySelectorAll('.kl-card').forEach(x => x.classList.remove('kl-selected'));
    if (opening) {
      el.classList.add('kl-selected');
      box.classList.remove('hidden');
      requestAnimationFrame(() => box.scrollIntoView({ behavior: 'smooth', block: 'start' }));
    } else {
      box.classList.add('hidden');
    }
  }
  function closeSolo() {
    document.getElementById('klatiene-solo').classList.add('hidden');
    document.querySelectorAll('.kl-card').forEach(x => x.classList.remove('kl-selected'));
  }
  window.toggleSolo = toggleSolo;
  window.closeSolo = closeSolo;
  document.querySelectorAll('.kl-card').forEach(card => {
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
    });
  });

  // Podcast carousel
  function scrollPodcast(dir) {
    const track = document.getElementById('podcast-track');
    if (!track) return;
    const card = track.querySelector('.pod-card');
    const amount = card ? card.offsetWidth + 24 : 320; // 24px = gap-6
    track.scrollBy({ left: dir * amount, behavior: 'smooth' });
  }
  window.scrollPodcast = scrollPodcast;

  // Keyboard activation for program cards
  document.querySelectorAll('.prog-card').forEach(card => {
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
    });
  });
</script>

</body>
</html>
